{
    "version": 2,
    "buildCommand": "npx prisma generate && cd mini-app && npm install && npx vite build",
    "outputDirectory": ".",
    "functions": {
        "api/**/*.ts": {
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "rewrites": [
        { "source": "/app/vite.svg", "destination": "/mini-app/dist/vite.svg" },
        { "source": "/app/assets/(.*)", "destination": "/mini-app/dist/assets/$1" },
        { "source": "/app(.*)", "destination": "/mini-app/dist/index.html" }
    ],
    "headers": [
        {
            "source": "/mini-app/dist/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron-daily",
            "schedule": "0 23 * * *"
        },
        {
            "path": "/api/cron-stock",
            "schedule": "0 8 * * *"
        }
    ]
}